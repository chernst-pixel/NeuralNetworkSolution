<Window x:Class="NeuralNet.Training.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NeuralNet.Training.WPF"
        mc:Ignorable="d"
        Title="Training Interface" Height="450" Width="800">
    <Grid>
        <Button x:Name="btn_load_model"     Content="Lade Model"            HorizontalAlignment="Left" Margin="45, 20,0,0" VerticalAlignment="Top" Height="50" Width="150" Click="btn_load_model_Click"/>
        <Button x:Name="btn_load_training"  Content="Lade Trainings Daten"  HorizontalAlignment="Left" Margin="45, 75,0,0" VerticalAlignment="Top" Height="50" Width="150" Click="btn_load_training_Click" RenderTransformOrigin="0.487,0.474"/>
        <Button x:Name="btn_load_test"      Content="Lade Test Daten"       HorizontalAlignment="Left" Margin="45,130,0,0" VerticalAlignment="Top" Height="50" Width="150" Click="btn_load_test_Click"/>
        <Button x:Name="btn_start_epoch"    Content="Starte Epochen"        HorizontalAlignment="Left" Margin="45,185,0,0" VerticalAlignment="Top" Height="50" Width="150" Click="btn_start_epoch_Click"/>
        <Button x:Name="btn_start_test"     Content="Starte Test"           HorizontalAlignment="Left" Margin="45,240,0,0" VerticalAlignment="Top" Height="50" Width="150" Click="btn_start_test_Click"/>
        <Label x:Name="lbl_status"          Content=""                      HorizontalAlignment="Left" Height="270" Margin="210, 20,0,0" VerticalAlignment="Top" Width="200"/>
        <Label x:Name="lbl_error"           Content=""                      HorizontalAlignment="Left" Height="100" Margin=" 45,300,0,0" VerticalAlignment="Top" Width="700"/>
        <Label x:Name="lbl_update"          Content=""                      HorizontalAlignment="Left" Height="170" Margin="420, 20,0,0" VerticalAlignment="Top" Width="200"/>
        <Label x:Name="lbl_result"          Content=""                      HorizontalAlignment="Left" Height="100" Margin="420,190,0,0" VerticalAlignment="Top" Width="200"/>
    </Grid>
</Window>
