<Window x:Class="NeuralNet.Interface.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NeuralNet.Interface"
        mc:Ignorable="d"
        Title="Interface" Height="450" Width="800">
    <Grid>
        <Image  x:Name="img_drawing"                 HorizontalAlignment="Left" Height="280" Margin="90,90,0,0"   VerticalAlignment="Top" Width="280" MouseMove="img_drawing_MouseMove"/>
        <Label  x:Name="lbl_result"  Content=""      HorizontalAlignment="Left" Height="280" Margin="400,90,0,0"  VerticalAlignment="Top" Width="140"/>
        <Label x:Name="lbl_error"    Content=""      HorizontalAlignment="Left" Height="50"  Margin="90,25,0,0"   VerticalAlignment="Top" Width="595"/>
        <Button x:Name="btn_clear"   Content="Clear" HorizontalAlignment="Left" Height="70"  Margin="545,165,0,0" VerticalAlignment="Top" Width="140" Click="btn_clear_Click"/>
        <Button x:Name="btn_send"    Content="Test"  HorizontalAlignment="Left" Height="70"  Margin="545,90,0,0"  VerticalAlignment="Top" Width="140" Click="btn_send_Click"/>
        
        <Border BorderBrush="Black" BorderThickness="3" HorizontalAlignment="Left" Height="280" Margin="90,90,0,0" VerticalAlignment="Top" Width="280" />
        


    </Grid>
</Window>
